# Server
PORT=4000
NODE_ENV=development

# DynamoDB (local)
# For DynamoDB Local, AWS_* values are dummies required by the SDK but unused locally.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_ENDPOINT=http://localhost:8000

# Table names (prefixed so multiple envs can share one DynamoDB)
TABLE_PREFIX=SmartOps_

# Auth
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# Seed admin (used by scripts/seed.js)
SEED_ADMIN_EMAIL=admin@smartops.dev
SEED_ADMIN_PASSWORD=Admin@123
