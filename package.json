{
  "name": "smart-ops-system",
  "version": "1.0.0",
  "description": "Smart Internal Operations System - task management with RBAC, activity logging, and workflow insights. Built on Node + Express + DynamoDB.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:start": "node scripts/dynamodb-local.js",
    "create-tables": "node scripts/createTables.js",
    "seed": "node scripts/seed.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "operations",
    "task-management",
    "rbac",
    "dynamodb",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dynamodb-local": "^0.0.35",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3"
  }
}
